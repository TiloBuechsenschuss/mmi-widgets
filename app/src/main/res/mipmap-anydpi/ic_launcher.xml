<?xml version="1.0" encoding="utf-8"?>
<!--
  Active launcher icon = concept 1f "Split tile".
  To switch to concept 1d "Prompt", replace "split" with "prompt" in the three
  drawable references below (and in ic_launcher_round.xml). Both layer sets live
  in res/drawable/ic_launcher_{split,prompt}_{background,foreground}.xml.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_split_background" />
    <foreground android:drawable="@drawable/ic_launcher_split_foreground" />
    <monochrome android:drawable="@drawable/ic_launcher_split_foreground" />
</adaptive-icon>
