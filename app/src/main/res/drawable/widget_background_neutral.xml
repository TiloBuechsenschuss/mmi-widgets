<?xml version="1.0" encoding="utf-8"?>
<!--
  Neutral dark tile used behind the 1x1 icon widget. Kept colour-neutral (not green like
  widget_background.xml) so both the green "on" and red "off" phone icons stay legible.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/widget_background_neutral" />
    <corners android:radius="16dp" />
</shape>
