<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon concept 1d "Prompt" - background layer.
  Near-black tile with a soft radial glow toward the top-left,
  approximating the design's radial-gradient(120% 120% at 30% 20%, #14171c, #0a0b0d).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32.4"
                android:centerY="21.6"
                android:gradientRadius="92">
                <item android:offset="0.0" android:color="#14171C" />
                <item android:offset="0.7" android:color="#0A0B0D" />
                <item android:offset="1.0" android:color="#0A0B0D" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
